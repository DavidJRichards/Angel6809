2527   F0FB F0 08              BEQ IPS3        ;LSB OF SOL MASK IS 0 , DO MSB
2528   F0FD 0D 78 A4           ORA IOUTL       ;SET THE SOLENOID IN THE PATTERN
2529   F100 8D 78 A4           STA IOUTL
